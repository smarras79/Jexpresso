NOTICE: replace mpiexec with mpirun if that's what you use.

The commands above use mpiexec() from MPI.jl, which points at the bundled
MPICH_jll launcher. There are TWO different OpenMPI situations; check which one
you are in first:

    using MPI
    MPI.versioninfo()
    #  binary = OpenMPI_jll + a ~/.julia/artifacts/... path  -> CASE A (JLL)
    #  library = OpenMPI    + a system path (e.g. /opt/homebrew) -> CASE B (system)


#Parallel - CASE A: OpenMPI from the JLL (OpenMPI_jll)
#
# This is the common case if you switched MPI.jl away from MPICH_jll with
# MPIPreferences.use_jll_binary("OpenMPI_jll"). The launcher lives inside a
# Julia artifact and depends on other artifacts (e.g. Hwloc_jll's
# libhwloc.15.dylib). Calling a BARE `mpirun` from a shell fails with
#   dyld: Library not loaded: @rpath/libhwloc.15.dylib
# because the artifact library environment is only set up when the launcher is
# invoked THROUGH MPI.jl. So launch with the mpiexec() do-block (NOT bare
# mpirun, and NOT $(mpiexec()) interpolation - the do-block is what sets the
# environment that lets prte/mpirun find libhwloc):
using MPI
JULIA = Base.julia_cmd()
mpiexec() do exe
    run(`$exe -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "thetaTracers")'`)
end
mpiexec() do exe
    run(`$exe -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "3d")'`)
end
mpiexec() do exe
    run(`$exe -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "city2d")'`)
end
mpiexec() do exe
    run(`$exe -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "kelvinHelmholtzChan2022")'`)
end


#Parallel - CASE B: a real system OpenMPI (e.g. Homebrew, MacPorts, HPC module)
#
# Working sequence (Homebrew OpenMPI 5.x, libmpi in /opt/homebrew/lib).
#
# Two independent things must both point at the SAME OpenMPI:
#   1. the libmpi the worker Julia processes load  -> set by MPIPreferences
#   2. the mpirun launcher + the prte daemon/plugins/libs it uses
# MPIPreferences ONLY controls (1).
#
# IMPORTANT (Open MPI 5.x): mpirun is a front-end that launches the PRRTE daemon
# `prte` and loads plugins/libs from its install prefix. Open MPI is relocatable
# and OVERRIDES that prefix from the env var OPAL_PREFIX (also PRTE_PREFIX /
# PMIX_PREFIX). OpenMPI_jll's __init__ exports OPAL_PREFIX pointing at its
# artifact, so once that JLL has been loaded in the session (or the var is left
# in your shell), EVERY Open MPI you launch - even a full-path Homebrew mpirun -
# is redirected into the artifact and runs the artifact's prte, dying with
# `Library not loaded: @rpath/libhwloc.15.dylib`. PATH does NOT fix this; the
# env var wins. Inspect with:
#   for k in ("OPAL_PREFIX","PRTE_PREFIX","PMIX_PREFIX"); println(k," => ",get(ENV,k,"(unset)")); end
#
# => Unset OPAL_PREFIX/PRTE_PREFIX/PMIX_PREFIX for the launch so Homebrew mpirun
#    uses its own /opt/homebrew prefix (matching the libmpi above).
#
# Bind MPI.jl BEFORE the first `using MPI` (it reads preferences at load time),
# so no Julia restart is needed. If MPI was already loaded, restart Julia once.
# Find the lib dir with `ompi_info --path libdir` if it is not /opt/homebrew/lib.
# add MPIPreferences once if needed:  julia>] then  pkg> add MPIPreferences
julia --project=.

using MPIPreferences
MPIPreferences.use_system_binary(; extra_paths = ["/opt/homebrew/lib"])
using MPI                 # picks up the system OpenMPI (no restart needed here)
using Jexpresso
JULIA = Base.julia_cmd()
mpi = "/opt/homebrew/bin/mpirun"
withenv("OPAL_PREFIX" => nothing,   # critical: drop the OpenMPI_jll artifact prefix
        "PRTE_PREFIX" => nothing,
        "PMIX_PREFIX" => nothing,
        "PATH" => "/opt/homebrew/bin:" * get(ENV, "PATH", "")) do
    run(`$mpi -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "3d")'`)
    run(`$mpi -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "thetaTracers")'`)
    run(`$mpi -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "city2d")'`)
    run(`$mpi -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "kelvinHelmholtzChan2022")'`)
end

