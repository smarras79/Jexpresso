using MPIPreferences
MPIPreferences.use_system_binary()   # auto-detects the OpenMPI on your PATH
# -> writes LocalPreferences.toml; restart Julia, then verify:
using MPI
MPI.MPI_LIBRARY            # should report OpenMPI
MPI.versioninfo()         # confirms "library = OpenMPI" and the mpirun path
# To go back to the bundled MPICH later: MPIPreferences.use_jll_binary(); restart.

# RUN: call the system `mpirun` directly instead of mpiexec(). Everything else
# (the -n count and the Julia command) is identical.
using MPI
JULIA = Base.julia_cmd()
run(`mpirun -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "thetaTracers")'`)
run(`mpirun -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "3d")'`)
run(`mpirun -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "city2d")'`)
run(`mpirun -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "kelvinHelmholtzChan2022")'`)

