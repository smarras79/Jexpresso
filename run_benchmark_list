using MPIPreferences
MPIPreferences.use_system_binary(; extra_paths = ["/opt/homebrew/lib"],
                                   mpiexec     = "/opt/homebrew/bin/mpirun")
# -> writes LocalPreferences.toml; restart Julia, then verify:
using MPI
MPI.versioninfo()         # "library = OpenMPI" + the system mpirun path
# To go back to the bundled MPICH later: MPIPreferences.use_jll_binary(); restart.

# RUN: call the system mpirun by FULL PATH (a bare `mpirun` may resolve to the
# JLL launcher in ~/.julia/artifacts instead - see CASE A):
using MPI
JULIA = Base.julia_cmd()
run(`/opt/homebrew/bin/mpirun -n 3 $JULIA --project=. -e 'using Jexpresso; Jexpresso.run_case("CompEuler", "3d")'`)

# NOTICE (system OpenMPI):
#  - If -n exceeds your physical cores, add --oversubscribe.
#  - If you run as root (e.g. in a container), add --allow-run-as-root.